generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Titulo {
  id_titulo    Int        @id @default(autoincrement())
  tx_descricao String     @unique @db.VarChar(150)
  professores  Professor[]

  @@map("titulo")
}

model TipoCurso {
  id_tipo_curso Int     @id @default(autoincrement())
  tx_descricao  String  @unique @db.VarChar(150)
  cursos        Curso[]

  @@map("tipo_curso")
}

model TipoDisciplina {
  id_tipo_disciplina Int          @id @default(autoincrement())
  tx_descricao       String       @unique @db.VarChar(150)
  disciplinas        Disciplina[]

  @@map("tipo_disciplina")
}


model Instituicao {
  id_instituicao Int     @id @default(autoincrement())
  tx_sigla       String  @unique @db.VarChar(15)
  tx_descricao   String  @unique @db.VarChar(150)
  cursos         Curso[]

  @@map("instituicao")
}

model Professor {
  id_professor    Int       @id @default(autoincrement())
  id_titulo       Int
  tx_nome         String    @db.VarChar(50)
  tx_sexo         String    @default("m") @db.Char(1)
  tx_estado_civil String    @default("s") @db.Char(1)
  dt_nascimento   DateTime  @db.Date
  tx_telefone     String    @db.VarChar(13)
  titulo          Titulo    @relation(fields: [id_titulo], references: [id_titulo], onUpdate: Cascade, onDelete: Cascade)
  leciona         Leciona[]

  @@map("professor")
}

model Curso {
  id_curso       Int          @id @default(autoincrement())
  id_instituicao Int
  id_tipo_curso  Int
  tx_descricao   String       @db.VarChar(150)
  instituicao    Instituicao  @relation(fields: [id_instituicao], references: [id_instituicao], onUpdate: Cascade, onDelete: Cascade)
  tipo_curso     TipoCurso    @relation(fields: [id_tipo_curso], references: [id_tipo_curso], onUpdate: Cascade, onDelete: Cascade)
  disciplinas    Disciplina[]

  @@unique([id_instituicao, id_tipo_curso, tx_descricao])
  @@map("curso")
}

model Disciplina {
  id_disciplina      Int            @id @default(autoincrement())
  id_curso           Int?
  id_tipo_disciplina Int
  tx_sigla           String         @unique @db.VarChar(10)
  tx_descricao       String         @unique @db.VarChar(150)
  in_periodo         Int
  in_carga_horaria   Int
  curso              Curso?         @relation(fields: [id_curso], references: [id_curso], onUpdate: Cascade, onDelete: Cascade)
  tipo_disciplina    TipoDisciplina @relation(fields: [id_tipo_disciplina], references: [id_tipo_disciplina], onUpdate: Cascade, onDelete: Cascade)
  leciona            Leciona[]
  cursa              Cursa[]

  @@map("disciplina")
}


model Leciona {
  id_professor  Int
  id_disciplina Int
  professor     Professor  @relation(fields: [id_professor], references: [id_professor], onUpdate: Cascade, onDelete: Cascade)
  disciplina    Disciplina @relation(fields: [id_disciplina], references: [id_disciplina], onUpdate: Cascade, onDelete: Cascade)

  @@id([id_professor, id_disciplina])
  @@map("leciona")
}

model Aluno {
  id_aluno      Int      @id @default(autoincrement())
  tx_nome       String   @db.VarChar(100)
  tx_sexo       String   @db.Char(1)
  dt_nascimento DateTime @db.Date
  cursa         Cursa[]

  @@map("aluno")
}

model Cursa {
  id_aluno      Int
  id_disciplina Int
  in_ano        Int
  in_semestre   Int
  in_faltas     Int      @default(0)
  nm_nota1      Decimal? @db.Decimal(4, 2)
  nm_nota2      Decimal? @db.Decimal(4, 2)
  nm_nota3      Decimal? @db.Decimal(4, 2)
  bl_aprovado   Boolean  @default(false)
  aluno         Aluno      @relation(fields: [id_aluno], references: [id_aluno], onUpdate: Cascade, onDelete: Cascade)
  disciplina    Disciplina @relation(fields: [id_disciplina], references: [id_disciplina], onUpdate: Cascade, onDelete: Cascade)

  @@id([id_aluno, id_disciplina, in_ano, in_semestre])
  @@map("cursa")
}
