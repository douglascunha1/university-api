{
  "info": {
    "name": "University API",
    "description": "Collection completa da University API — NestJS + Prisma + PostgreSQL.\n\nBase URL configurada via variável de ambiente `{{baseUrl}}`.\n\nConfigure em: Environments → selecione 'University API Local' ou ajuste manualmente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "university-api-collection-v1"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Títulos",
      "description": "Gerenciamento de títulos acadêmicos (Doutor, Mestre, Especialista...)",
      "item": [
        {
          "name": "Listar todos os títulos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/titulos",
              "host": ["{{baseUrl}}"],
              "path": ["titulos"]
            }
          }
        },
        {
          "name": "Buscar título por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/titulos/1",
              "host": ["{{baseUrl}}"],
              "path": ["titulos", "1"]
            }
          }
        },
        {
          "name": "Criar título",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tx_descricao\": \"Doutor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/titulos",
              "host": ["{{baseUrl}}"],
              "path": ["titulos"]
            }
          }
        },
        {
          "name": "Atualizar título",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tx_descricao\": \"Doutor em Ciências\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/titulos/1",
              "host": ["{{baseUrl}}"],
              "path": ["titulos", "1"]
            }
          }
        },
        {
          "name": "Remover título",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/titulos/1",
              "host": ["{{baseUrl}}"],
              "path": ["titulos", "1"]
            }
          }
        }
      ]
    },
